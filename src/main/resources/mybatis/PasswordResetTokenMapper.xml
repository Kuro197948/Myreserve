<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.app.mapper.PasswordResetTokenMapper">

    <resultMap id="passwordResetTokenMap" type="com.example.app.domain.PasswordResetToken">
        <id property="id" column="id"/>
        <result property="memberId" column="member_id"/>
        <result property="token" column="token"/>
        <result property="expiresAt" column="expires_at"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" parameterType="com.example.app.domain.PasswordResetToken">
        INSERT INTO password_reset_tokens (
            member_id,
            token,
            expires_at,
            created_at
        ) VALUES (
            #{memberId},
            #{token},
            #{expiresAt},
            #{createdAt}
        )
    </insert>

    <select id="selectByToken" resultMap="passwordResetTokenMap">
        SELECT
            id,
            member_id,
            token,
            expires_at,
            created_at
        FROM password_reset_tokens
        WHERE token = #{token}
    </select>

    <delete id="deleteByToken">
        DELETE FROM password_reset_tokens
        WHERE token = #{token}
    </delete>

    <delete id="deleteByMemberId">
        DELETE FROM password_reset_tokens
        WHERE member_id = #{memberId}
    </delete>

</mapper>