<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.app.mapper.NewsDetailMapper">

  <insert id="insert" parameterType="com.example.app.domain.NewsDetail">
    INSERT INTO news_details (news_id, article, photo)
    VALUES (#{newsId}, #{article}, #{photo})
  </insert>

  <delete id="deleteByNewsId" parameterType="int">
    DELETE FROM news_details
    WHERE news_id = #{newsId}
  </delete>

  <select id="selectByNewsId"
          parameterType="int"
          resultType="com.example.app.domain.NewsDetail">
    SELECT
      news_id AS newsId,
      article,
      photo
    FROM news_details
    WHERE news_id = #{newsId}
  </select>

</mapper>